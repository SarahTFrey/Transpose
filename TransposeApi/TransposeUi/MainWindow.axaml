<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="TransposeUi.MainWindow"
        xmlns:local="clr-namespace:TransposeUi"
        Title="TransposeUi"
        x:DataType="local:ViewModel">
    <TabControl>
        <TabItem Header="Tab Input">
            <Grid RowDefinitions="Auto, *">
                <StackPanel Orientation="Horizontal">
                    <ComboBox Grid.Row="0" SelectedIndex="0">
                        <ComboBoxItem Content="Guitar Standard - E A D G B E"/>
                    </ComboBox>
                    <Button Content="Translate" Click="TranslateTabs" />
                </StackPanel>
                <TextBox Grid.Row="1" Text="{Binding TabText}" TextWrapping="Wrap" AcceptsTab="True" AcceptsReturn="True"  />
            </Grid>
        </TabItem>
        <TabItem Header="S.P.N Output">
            
        </TabItem>
        <TabItem Header="Midi">
            
        </TabItem>
    </TabControl>
</Window>
